# Node and Application configuration
PORT=5000
NODE_ENV=production

# Core database URL (Used by PostgreSQL)
# When using docker-compose, this is provided automatically. To use externally:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/civic_issue_portal

# Session Secret (change this in production!)
SESSION_SECRET=development_secret_key_change_me_in_production

# Replit Specific/Auth Configurations (Optional or as needed)
# REPL_ID=local_dev_repl_id
# ISSUER_URL=https://replit.com/oidc
